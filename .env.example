# ─────────────────────────────────────────────────────────────────────
# CLAIR Frontend - 환경변수 템플릿
#
# 사용법:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# clair-backend API URL
# ⚠️  macOS: localhost가 IPv6(::1)로 resolve되어 연결 실패할 수 있음
#     반드시 127.0.0.1 사용
VITE_API_URL=http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000

# Frontend URL (공유 링크 생성용)
VITE_FRONT_URL=http://localhost:5173